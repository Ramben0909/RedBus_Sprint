package DriverManager;

import org.testng.ITestContext;
import org.testng.ITestListener;
import org.testng.ITestResult;

public class BrowserParameterListener implements ITestListener {

    // ── fires on the MAIN thread — store browser name for later ──────
    @Override
    public void onStart(ITestContext context) {
        String browser = context.getCurrentXmlTest()
                                .getParameter("browser");
        if (browser != null) {
            // save it at context level so worker threads can read it
            context.setAttribute("browser", browser);
            System.out.println("Browser set to: " + browser);
        }
    }

    // ── fires on EACH WORKER THREAD — set ThreadLocal here ───────────
    @Override
    public void onTestStart(ITestResult result) {
        String browser = (String) result.getTestContext()
                                        .getAttribute("browser");
        if (browser != null) {
            DriverManagerRB.setBrowserName(browser); // ← set on THIS worker thread
        }
    }
}