<?xml version="1.0" encoding="UTF-8"?>
<suite name="RedRail Full Test Suite" verbose="1" parallel="none">

    <listeners>
        <listener class-name="Hooks.Hooks_SearchTrains.BrowserParameterListener"/>
    </listeners>

    <!-- Module 1 — SDC -->
    <test name="SDC Module">
        <classes>
            <class name="testRunner.Runner_SDC.TestRunner"/>
        </classes>
    </test>

    <!-- Module 2 — Train Status -->
    <test name="Train Status Module">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="testRunner.Runner_trainstatus.AvailabilityTestRunner"/>
            <class name="testRunner.Runner_trainstatus.SearchTestRunner"/>
            <class name="testRunner.Runner_trainstatus.TestRunner"/>
        </classes>
    </test>

    <!-- Module 3 — AP -->
    <test name="AP Module">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="testRunner.runnerAP.TestRunner"/>
        </classes>
    </test>

    <!-- Module 4 — Train Search (your module) -->
    <test name="Train Search - Search Scenarios">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="testRunner.TrainSearchResults.TestRunnerSearch"/>
        </classes>
    </test>

    <test name="Train Search - Results Scenarios">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="testRunner.TrainSearchResults.TestRunnerResults"/>
        </classes>
    </test>

</suite>