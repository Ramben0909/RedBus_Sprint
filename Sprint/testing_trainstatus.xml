<?xml version="1.0" encoding="UTF-8"?>
<suite name="Train Status Test Suite" verbose="1" parallel="none">

    <listeners>
        <listener class-name="Hooks.Hooks_SearchTrains.BrowserParameterListener"/>
    </listeners>

    <test name="Train Status Module">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="testRunner.Runner_trainstatus.AvailabilityTestRunner"/>
            <class name="testRunner.Runner_trainstatus.SearchTestRunner"/>
            <class name="testRunner.Runner_trainstatus.TestRunner"/>
        </classes>
    </test>

</suite>